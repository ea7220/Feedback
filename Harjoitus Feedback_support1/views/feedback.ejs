<!DOCTYPE html>
<html lang="fi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> | Tuki- ja palauteportaali
  </title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <%- include("header", { activePage: activePage }) %>

    <main class="container">
      <section class="page-title">
        <div>
          <h2>
            <%= title %>
          </h2>
          <p>Asiakkaiden ja vieraiden antama palaute.</p>
        </div>
        <span class="count">
          <%= rows.length %> palautetta
        </span>
      </section>

      <div class="card table-wrap">
        <table>
          <thead>
            <tr>
              <th>Asiakas</th>
              <th>Saapunut</th>
              <th>Lähettäjä</th>
              <th>Email</th>
              <th>Palaute</th>
              <th>Käsitelty</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(row=> { %>
              <tr>
                <td><strong>
                    <%= row.customer_name || "Vieras" %>
                  </strong></td>
                <td>
                  <%= row.arrived ? row.arrived.toLocaleString("fi-FI") : "-" %>
                </td>
                <td>
                  <%= row.user_name || row.guest_name || "Anonyymi" %>
                </td>
                <td>
                  <%= row.email || row.guest_email || "-" %>
                </td>
                <td>
                  <%= row.feedback || "-" %>
                </td>
                <td>
                  <% if (row.handled) { %>
                    <span class="badge ok">
                      <%= row.handled.toLocaleString("fi-FI") %>
                    </span>
                    <% } else { %>
                      <span class="badge warning">Kesken</span>
                      <% } %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </main>
</body>

</html>